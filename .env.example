# Supabase Configuration
# Replace these with your actual Supabase project values

# Your Supabase project URL (found in your Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon/public key (found in your Supabase dashboard under Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Your Supabase service role key (found in your Supabase dashboard under Settings > API)
# This key has elevated privileges - keep it secure and never expose it to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: Database direct connection (if needed)
# DATABASE_URL=postgresql://postgres:[password]@db.[project-id].supabase.co:5432/postgres

# AI Provider Configuration
# Supported values: ollama, openai, fallback
AI_PROVIDER=ollama

# Ollama provider
# Local example: http://localhost:11434
# Current production endpoint example: https://193.123.83.173.sslip.io
OLLAMA_BASE_URL=https://193.123.83.173.sslip.io
OLLAMA_MODEL=llama3
# Store the real key only in your secret manager or local .env.local
OLLAMA_API_KEY=your-ollama-api-key-here
OLLAMA_AUTH_HEADER=X-ERP-AI-Key
AI_PROVIDER_TIMEOUT_MS=120000

# Optional OpenAI provider
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com
# OPENAI_MODEL=gpt-4.1-mini

# Instructions:
# 1. Go to your Supabase dashboard (https://supabase.com/dashboard)
# 2. Select your project
# 3. Go to Settings > API
# 4. Copy the Project URL and paste it as NEXT_PUBLIC_SUPABASE_URL
# 5. Copy the anon public key and paste it as NEXT_PUBLIC_SUPABASE_ANON_KEY
# 6. Copy the service_role key and paste it as SUPABASE_SERVICE_ROLE_KEY
# 7. Save this file and restart your development server
